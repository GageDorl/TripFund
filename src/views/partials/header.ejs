<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripFund</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <nav>
        <div class="logo"><a href="/">TripFund</a></div>
        <ul class="nav-links">
            <% Object.keys(paths).forEach(function(route) { %>
                <li><a href="<%= paths[route] %>" class="<%= getCurrentPath() === paths[route] ? 'active' : '' %>"><%= route.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %></a></li>
            <% }); %>
        </ul>
    </nav>