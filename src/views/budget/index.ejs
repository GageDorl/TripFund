<%- include('../partials/header') %>
<main class="container">
  <header style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem">
    <h1>Budget — <%= trip.name %></h1>
    <div>
      <a class="btn btn-secondary" href="/trips/<%= trip.id %>">Back to Trip</a>
    </div>
  </header>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <section class="budget-list">
    <% if (!items || items.length === 0) { %>
      <div class="empty">No budget items yet.</div>
    <% } %>
    <table class="budget-table">
      <thead>
        <tr><th>Category</th><th>Planned</th><th></th></tr>
      </thead>
      <tbody>
        <% (items || []).forEach(function(item){ %>
          <% const cat = (categories || []).find(c => c.id === item.categoryId) || { name: item.categoryId }; %>
          <tr>
            <td><%= cat.name %></td>
            <td>$<%= Number(item.plannedAmount || 0).toFixed(2) %></td>
            <td>
              <% if (currentUser && trip && currentUser.username === trip.userId) { %>
                <form method="post" action="/trips/<%= trip.id %>/budget/<%= item.id %>/delete" onsubmit="return confirm('Delete budget item?')">
                  <button type="submit" class="btn btn-link">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section style="margin-top:1rem" class="budget-form">
    <h2>Add budget item</h2>
    <form method="post" action="/trips/<%= trip.id %>/budget">
      <label>Category:
        <select name="categoryId" class="form-control">
          <% (categories || []).forEach(function(cat){ %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Planned amount: <input name="plannedAmount" type="number" step="0.01" class="form-control" /></label>
      <div style="margin-top:0.5rem">
        <button type="submit" class="btn btn-primary">Add</button>
      </div>
    </form>
  </section>
</main>
<%- include('../partials/footer') %>
