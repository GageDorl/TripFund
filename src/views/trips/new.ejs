<%- include("../partials/header") %>

<main class="container new-trip-container">
    <section class="form-card">
        <header>
            <h1>Create a New Trip</h1>
            <p class="muted">Tell your supporters where you're going and why — keep it concise and inspiring.</p>
        </header>

        <form action="/trips/new" method="POST" class="trip-form" data-validate>
            <div class="two-col">
                <div class="form-group">
                    <label for="name">Trip Name</label>
                    <input type="text" id="name" name="name" placeholder="Weekend in Lisbon" required aria-label="Trip name" value="<%= (addValues && addValues.name) || '' %>">
                </div>

                <div class="form-group">
                    <label for="destination">Destination</label>
                    <input type="text" id="destination" name="destination" placeholder="Lisbon, Portugal" required aria-label="Destination" value="<%= (addValues && addValues.destination) || '' %>">
                </div>
            </div>

            <div class="two-col">
                <div class="form-group">
                    <label for="startDate">Start Date</label>
                    <input type="date" id="startDate" name="startDate" required aria-label="Start date" value="<%= (addValues && addValues.startDate) || '' %>">
                </div>
                <div class="form-group">
                    <label for="endDate">End Date</label>
                    <input type="date" id="endDate" name="endDate" required aria-label="End date" value="<%= (addValues && addValues.endDate) || '' %>">
                </div>
            </div>

            <div class="form-group">
                <label for="cost">Target Cost (USD)</label>
                <input type="number" id="cost" name="cost" min="0" step="0.01" placeholder="e.g. 1200.00" required aria-label="Target cost" value="<%= (addValues && addValues.cost) || '' %>">
            </div>

            <div class="form-group">
                <label for="description">Description (optional)</label>
                <textarea id="description" name="description" rows="4" placeholder="Why are you going? Who will you meet?" aria-label="Description"><%= (addValues && addValues.description) || '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Trip</button>
                <a href="/trips" class="btn btn-secondary">Cancel</a>
            </div>

            <%- include('../partials/form-errors', { error: error, errors: null }) %>
        </form>
    </section>
</main>

<%- include("../partials/footer") %>