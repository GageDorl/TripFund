<%- include('../partials/header') %>
<h1>Create Recap for <%= trip.name %></h1>

<% if (error) { %>
  <p style="color:red"><%= error %></p>
<% } %>

<form method="post" action="/trips/<%= trip.id %>/recap">
  <label>Title: <input name="title" required /></label><br />
  <label>Body: <textarea name="body" required></textarea></label><br />
  <label>Total cost: <input name="totalCost" type="number" step="0.01" /></label><br />
  <label>Lessons learned: <textarea name="lessonsLearned"></textarea></label><br />
  <label>Recommendation: <textarea name="recommendation"></textarea></label><br />
  <button type="submit">Publish Recap</button>
</form>

<%- include('../partials/footer') %>
