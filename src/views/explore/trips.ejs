<%- include('../partials/header') %>
<main class="container">
  <header>
    <h1>Explore Trips</h1>
    <p class="muted">Browse public trips from the community.</p>
  </header>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <section class="trips-grid">
    <% (trips || []).forEach(function(t){ %>
      <article class="trip-small card">
        <a class="card-link" href="/trips/<%= t.id %>"></a>
        <div class="card-body">
          <h3 class="card-title"><a href="/trips/<%= t.id %>" class="trip-link"><%= t.name %></a></h3>
          <div class="card-sub muted"><%= t.destination %></div>
          <div class="card-dates muted"> <%= t.startDate %> — <%= t.endDate %></div>
          <p class="card-description"><%= t.description ? (t.description.length > 100 ? t.description.slice(0,100) + '…' : t.description) : '' %></p>

          <div class="progress-wrap">
            <div class="progress">
              <% const pct = (t.fundsRaised && t.cost) ? Math.min(100, Math.round((Number(t.fundsRaised)/Number(t.cost))*100)) : 0; %>
              <div class="progress-bar" style="width:<%= pct %>%"></div>
            </div>
            <div class="progress-meta"><span class="funds"><strong>$<%= t.fundsRaised || 0 %></strong></span> of $<%= t.cost || 0 %> (<%= pct %>%)</div>
          </div>
        </div>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/footer') %>
