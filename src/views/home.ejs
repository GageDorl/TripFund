<%- include("partials/header") %>
<div class="container">
    <h1>Welcome, <%= currentUser.name %>!</h1>
    <div class="dashboard">
        <div class="card">
            <h3>Your Trips</h3>
            <p>View and manage your upcoming and past trips.</p>
            <a href="/trips" class="btn btn-secondary">View Trips</a>
        </div>
        <div class="card">
            <h3>Funds Saved</h3>
            <p>Track the funds you've saved for your trips.</p>
            <a href="/funds" class="btn btn-secondary">View Funds</a>
        </div>
        <div class="card">
            <h3>Donations Received</h3>
            <p>View the donations you've received for your trips.</p>
            <a href="/donations" class="btn btn-secondary">View Donations</a>
        </div>
    </div>
    <h2>Active Trips</h2>
    <div class="active-trips">
        <% if (activeTrips.length === 0) { %>
            <p>You have no active trips. <a href="/trips/new">Create a new trip</a> to get started!</p>
        <% } else { %>
            <ul class="list-group">
                <% activeTrips.forEach(trip => { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <a href="/trips/<%= trip.id %>"><%= trip.name %></a>
                        <span class="badge badge-primary badge-pill"><%= trip.status %></span>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </div>
</div>
<%- include("partials/footer") %>