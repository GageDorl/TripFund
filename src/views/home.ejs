<%- include("partials/header") %>

<main class="container home-container">
    <header class="home-hero">
        <div>
            <h1>Welcome back, <%= currentUser.username %>!</h1>
            <p class="muted">Manage your trips, track funds, and see recent activity at a glance.</p>
        </div>
        <div>
            <a href="/trips/new" class="btn btn-primary">Create Trip</a>
                        <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'moderator')) { %>
                            <a href="/moderation/reports" class="btn btn-secondary" style="margin-left:0.5rem">Moderation</a>
                        <% } %>
                        <% if (currentUser && currentUser.role === 'admin') { %>
                            <a href="/admin" class="btn btn-secondary" style="margin-left:0.5rem">Admin</a>
                        <% } %>
        </div>
    </header>

    <section class="stats-grid">
        <div class="stat-card">
            <h4>Your Trips</h4>
            <div class="stat-value"><%= (userTrips && userTrips.length) || 0 %></div>
            <p class="muted">Upcoming and past trips</p>
        </div>
        <div class="stat-card">
            <h4>Funds Saved</h4>
            <div class="stat-value">$0.00</div>
            <p class="muted">Track your goal progress</p>
        </div>
        <div class="stat-card">
            <h4>Donations</h4>
            <div class="stat-value">$0.00</div>
            <p class="muted">Total contributions received</p>
        </div>
    </section>

    <section class="active-trips">
        <h2>Active Trips</h2>
        <% const tripsToShow = userTrips || []; %>
        <% if (tripsToShow.length === 0) { %>
            <div class="empty">You have no active trips. <a href="/trips/new">Create a new trip</a> to get started!</div>
        <% } else { %>
            <div class="trips-row">
                <% tripsToShow.forEach(trip => { %>
                    <article class="trip-small">
                        <div class="trip-info">
                            <a class="trip-link" href="/trips/<%= trip.id %>"><strong><%= trip.name %></strong></a>
                            <div class="muted"><%= trip.destination || '—' %> • <%= trip.startDate ? formatDate(trip.startDate) : 'TBD' %></div>
                        </div>
                        <div class="trip-actions">
                            <a class="btn btn-secondary" href="/trips/<%= trip.id %>">View</a>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>
</main>

<%- include("partials/footer") %>