<%- include('../partials/header') %>
<main class="container">
  <header style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem">
    <h1>Admin Dashboard</h1>
  </header>

  <% if (metrics) { %>
    <section style="display:flex; gap:1rem; margin-bottom:1rem; flex-wrap:wrap">
      <div class="card"><strong>Total users</strong><div><%= metrics.totalUsers %></div></div>
      <div class="card"><strong>Total trips</strong><div><%= metrics.totalTrips %></div></div>
      <div class="card"><strong>Public trips</strong><div><%= metrics.publicTrips %></div></div>
      <div class="card"><strong>Recaps</strong><div><%= metrics.totalRecaps %></div></div>
      <div class="card"><strong>Contributions</strong><div><%= metrics.contributionsCount %> (Sum: <%= metrics.contributionsSum %>)</div></div>
      <div class="card"><strong>Open reports</strong><div><%= metrics.openReports %></div></div>
    </section>
  <% } %>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <section style="margin-bottom:1.5rem">
    <h2>Categories</h2>
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <table style="width:100%; border-collapse:collapse; margin-bottom:0.5rem">
      <thead><tr><th style="width:70%">Category</th><th>Actions</th></tr></thead>
      <tbody>
        <% (categories || []).forEach(function(c){ %>
          <tr>
            <td>
              <form method="post" action="/admin/categories/<%= c.id %>/edit" style="display:flex; gap:0.5rem; align-items:center">
                <input name="name" value="<%= c.name %>" required class="form-control" style="flex:1" />
                <input name="slug" value="<%= c.slug %>" class="form-control" style="width:140px" />
                <input name="description" value="<%= c.description %>" class="form-control" style="width:220px" />
            </td>
            <td style="display:flex; gap:6px; align-items:center">
                <button class="btn" type="submit">Save</button>
              </form>
              <form method="post" action="/admin/categories/<%= c.id %>/delete" onsubmit="return confirm('Delete category?')" style="display:inline">
                <button class="btn" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <form method="post" action="/admin/categories" id="add-category-form" data-validate>
      <label>Name: <input name="name" required aria-label="Category name" class="form-control" value="<%= (addValues && addValues.name) || '' %>" /></label>
      <label>Slug: <input name="slug" aria-label="Category slug" class="form-control" value="<%= (addValues && addValues.slug) || '' %>" /></label>
      <label>Description: <input name="description" aria-label="Category description" class="form-control" value="<%= (addValues && addValues.description) || '' %>" /></label>
      <button type="submit" class="btn btn-primary">Add Category</button>
    </form>
  </section>

  <section>
    <h2>Users</h2>
    <form method="post" action="/admin/users/bulk-role" id="bulk-role-form">
      <div style="margin-bottom:0.5rem; display:flex; gap:0.5rem; align-items:center">
        <select name="bulkRole" required>
          <option value="">-- set role for selected --</option>
          <option value="user">User</option>
          <option value="moderator">Moderator</option>
          <option value="admin">Admin</option>
        </select>
        <button class="btn" type="submit">Update Selected</button>
      </div>
    </form>
      <table style="width:100%; border-collapse:collapse">
        <thead><tr><th style="width:40px"><input id="select-all" type="checkbox" /></th><th>Username</th><th>Name</th><th>Email</th><th>Role</th><th></th></tr></thead>
        <tbody>
          <% (users || []).forEach(function(u){ %>
            <tr>
              <td><input type="checkbox" name="selectedUsers" value="<%= u.username %>" /></td>
              <td><%= u.username %></td>
              <td><%= u.name || '-' %></td>
              <td><%= u.email %></td>
              <td><%= u.role %></td>
              <td>
                <form method="post" action="/admin/users/<%= u.username %>/role">
                    
                  <select name="role">
                    <option value="user" <%= u.role==='user'?'selected':'' %>>User</option>
                    <option value="moderator" <%= u.role==='moderator'?'selected':'' %>>Moderator</option>
                    <option value="admin" <%= u.role==='admin'?'selected':'' %>>Admin</option>
                  </select>
                  <button class="btn" type="submit">Update</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    
  </section>

</main>
<%- include('../partials/footer') %>

<script>
  // disable buttons on submit to avoid double-post
  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('form').forEach(function(f){
      f.addEventListener('submit', function(e){
        var btns = f.querySelectorAll('button');
        btns.forEach(function(b){ b.disabled = true; });
      });
    });
    // select-all checkbox behavior for users table
    var selectAll = document.getElementById('select-all');
    if (selectAll) {
      selectAll.addEventListener('change', function(){
        var checked = selectAll.checked;
        document.querySelectorAll('input[name="selectedUsers"]').forEach(function(cb){ cb.checked = checked; });
      });
    }
    // bulk role form: gather selected checkboxes into hidden inputs before submit
    var bulkForm = document.getElementById('bulk-role-form');
    if (bulkForm) {
      bulkForm.addEventListener('submit', function(e){
        // remove previously appended hidden inputs
        Array.from(bulkForm.querySelectorAll('input[type=hidden][name="selectedUsers"]')).forEach(function(h){ h.remove(); });
        var checked = Array.from(document.querySelectorAll('input[name="selectedUsers"]:checked'));
        if (checked.length === 0) {
          e.preventDefault();
          alert('Please select at least one user to update.');
          return;
        }
        checked.forEach(function(cb){
          var h = document.createElement('input');
          h.type = 'hidden'; h.name = 'selectedUsers'; h.value = cb.value;
          bulkForm.appendChild(h);
        });
      });
    }
  });
</script>
