<%- include('../partials/header') %>
<main class="container">
  <header style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem">
    <h1>Itinerary — <%= trip.name %></h1>
    <div>
      <a class="btn btn-secondary" href="/trips/<%= trip.id %>">Back to Trip</a>
    </div>
  </header>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <section class="itinerary-list">
    <% if (!items || items.length === 0) { %>
      <div class="empty">No itinerary items yet.</div>
    <% } %>
    <% (items || []).forEach(function(item){ %>
      <div class="itinerary-item">
        <div style="display:flex; justify-content:space-between; align-items:center">
          <div><strong>Day <%= item.dayNumber %>:</strong> <%= item.title %></div>
          <div class="muted"><%= item.activityTime || '' %></div>
        </div>
        <div style="margin-top:0.5rem"> <em><%= item.location %></em> — <%= item.estimatedCost ? ('$' + Number(item.estimatedCost).toFixed(2)) : 'N/A' %></div>
        <% if (item.notes) { %>
          <p style="margin-top:0.5rem"><%= item.notes %></p>
        <% } %>
      </div>
    <% }) %>
  </section>

  <section style="margin-top:1rem" class="itinerary-form">
    <h2>Add item</h2>
    <form method="post" action="/trips/<%= trip.id %>/itinerary">
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.5rem">
        <label>Day number: <input name="dayNumber" type="number" class="form-control" /></label>
        <label>Time: <input name="activityTime" type="time" class="form-control" /></label>
      </div>
      <label>Title: <input name="title" class="form-control" /></label>
      <label>Location: <input name="location" class="form-control" /></label>
      <label>Estimated cost: <input name="estimatedCost" type="number" step="0.01" class="form-control" /></label>
      <label>Notes: <textarea name="notes" class="form-control"></textarea></label>
      <div style="margin-top:0.5rem">
        <button type="submit" class="btn btn-primary">Add Item</button>
      </div>
    </form>
  </section>
</main>
<%- include('../partials/footer') %>
